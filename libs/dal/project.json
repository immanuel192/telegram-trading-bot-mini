{
  "name": "dal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/dal/src",
  "projectType": "library",
  "tags": [
    "type:lib"
  ],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/libs/dal",
        "bundle": false,
        "main": "libs/dal/src/index.ts",
        "tsConfig": "libs/dal/tsconfig.lib.json",
        "generatePackageJson": false,
        "esbuildConfig": "libs/esbuild.config.common.ts",
        "assets": [
          "libs/dal/*.md"
        ]
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/dal/jest.config.ts",
        "runInBand": true
      }
    }
  }
}

# Application Configuration
APP_NAME=trade-manager
LOG_LEVEL=info
NODE_ENV=development
PORT=9003

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGODB_DBNAME=telegram-trading-bot-mini

# Sentry Configuration
SENTRY_DSN=https://your-sentry-dsn-here

# New Relic Configuration (optional, recommended for production)
# Get from https://newrelic.com
NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=trade-manager

# Redis Stream Configuration (Upstash Redis)
REDIS_URL=http://localhost:8000
REDIS_TOKEN=your-redis-token-here

# Stream Consumer Configuration
STREAM_CONSUMER_MODE=new

# PushSafer API Configuration
PUSHSAFER_API_KEY=your-pushsafer-api-key-here

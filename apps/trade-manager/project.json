{
  "name": "trade-manager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/trade-manager/src",
  "projectType": "application",
  "tags": [
    "type:app",
    "scope:trade"
  ],
  "implicitDependencies": [
    "shared-utils"
  ],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/trade-manager",
        "format": [
          "cjs"
        ],
        "bundle": false,
        "main": "apps/trade-manager/src/main.ts",
        "tsConfig": "apps/trade-manager/tsconfig.app.json",
        "generatePackageJson": true,
        "esbuildConfig": "libs/esbuild.config.common.ts"
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "dev": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "trade-manager:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/trade-manager/jest.config.ts",
        "passWithNoTests": true,
        "runInBand": true
      }
    }
  }
}

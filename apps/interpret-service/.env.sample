# Application Configuration
APP_NAME=interpret-service
NODE_ENV=development
PORT=9002
LOG_LEVEL=info

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGODB_DBNAME=telegram-trading-bot

# Sentry Configuration (for error tracking)
SENTRY_DSN=https://your-sentry-dsn-here

# New Relic Configuration (optional, recommended for production)
# Get from https://newrelic.com
NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=interpret-service

# Redis Stream Configuration (Upstash Redis)
REDIS_URL=http://localhost:8000
REDIS_TOKEN=fake-token

# Stream Consumer Configuration
STREAM_CONSUMER_MODE_REQUESTS=new

# PushSafer API Configuration (for push notifications)
PUSHSAFER_API_KEY=your-pushsafer-api-key-here

# AI Provider Selection
# AI_PROVIDER: Choose AI provider ('gemini' or 'groq')
# - gemini: Google Gemini AI with session caching (default)
# - groq: Groq AI with llama-3.1-8b-instant (faster, cheaper, stateless)
AI_PROVIDER=gemini

# AI Gemini Configuration
# AI_GEMINI_API_KEY: Gemini API authentication key for AI translation
AI_GEMINI_API_KEY=your-gemini-api-key-here
# AI_GEMINI_MODEL: Gemini model to use (default: gemini-2.5-flash-lite)
AI_GEMINI_MODEL=gemini-2.5-flash-lite

# AI Groq Configuration
# AI_GROQ_API_KEY: Groq API authentication key for AI translation
AI_GROQ_API_KEY=your-groq-api-key-here
# AI_GROQ_MODEL: Groq model to use (default: llama-3.1-8b-instant)
# Note: Only llama-3.1-8b-instant is supported for MVP
AI_GROQ_MODEL=llama-3.1-8b-instant

# Prompt Cache Configuration
# AI_PROMPT_CACHE_TTL_SECONDS: Time-to-live for prompt cache in seconds (default: 1800 = 30 minutes)
# Note: In-memory cache is used for MVP single instance deployment
AI_PROMPT_CACHE_TTL_SECONDS=1800

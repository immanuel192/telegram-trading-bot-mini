# Base Configuration
NODE_ENV=development
LOG_LEVEL=info
APP_NAME=telegram-trading-bot-mini

# MongoDB
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0&directConnection=true
MONGODB_DBNAME=telegram-trading-bot

# Redis
REDIS_URL=redis://localhost:6379

# Telegram Service
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# AI (Interpret Service)
LLM_API_KEY=
LLM_MODEL=gemini-pro-1.5
LLM_PROVIDER=gemini

# Monitoring
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# Notifications
PUSHSAFER_API_KEY=

# Trade Manager
WEBSOCKET_PORT=8080
RISK_FRACTION=0.01
MAX_DAILY_LOSS_PCT=5.0
